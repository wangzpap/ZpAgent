# 环境变量配置文件
# 将此文件复制为 .env 并填入 API_KEY

# ===== LLM API 配置 =====
# DeepSeek API（兼容 OpenAI 格式）
API_KEY=your-api-key-here
BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-v4-flash
TEMPERATURE=0.7
MAX_COMPLETION_TOKENS=2048
REQUEST_TIMEOUT=60
MAX_RETRIES=2

# ===== Agent 配置 =====
# ReAct 最大迭代次数（防止无限循环）
MAX_ITERATIONS=10

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8000
