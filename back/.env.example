# 环境变量配置文件
# 将此文件复制为 .env 并填入 API_KEY

# ===== LLM API 配置 =====
# DeepSeek API（兼容 OpenAI 格式）
API_KEY=your-api-key-here
BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-v4-flash
TEMPERATURE=0.7
MAX_COMPLETION_TOKENS=2048
REQUEST_TIMEOUT=60
MAX_RETRIES=2

# ===== Agent 配置 =====
# ReAct 最大迭代次数（防止无限循环）
MAX_ITERATIONS=10

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8000

# ===== 对话检查点存储后端（策略模式） =====
# 可选值: memory（内存，默认，开发用） | mysql（MySQL 持久化，生产用）
CHECKPOINT_BACKEND=memory
# ===== 会话元数据存储后端（策略模式） ，建议与CHECKPOINT_BACKEND一致=====
# 可选值: memory（内存，默认，开发用） | mysql（MySQL 持久化，生产用）
CONVERSATION_BACKEND=memory

# ===== MySQL 配置（CONVERSATION_BACKEND=mysql 或 CHECKPOINT_BACKEND=mysql 时共用） =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=zpagent
